{
  "buildCommand": "cd apps/web && npm run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "cd apps/web && npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/stripe/webhook",
      "destination": "/api/stripe/webhook"
    }
  ],
  "headers": [
    {
      "source": "/api/stripe/webhook",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
